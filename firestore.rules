rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "leaninkclothing@gmail.com" || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidOrder(data) {
      return hasRequiredFields(['userId', 'status', 'totalAmount', 'items']) &&
             data.userId is string &&
             data.status in ['pending', 'processing', 'completed', 'cancelled'] &&
             data.totalAmount is number &&
             data.items is list;
    }

    function isValidTemplate(data) {
      return hasRequiredFields(['title', 'description', 'imageUrl', 'price']) &&
             data.title is string && data.title.size() < 100 &&
             data.description is string && data.description.size() < 2000 &&
             data.imageUrl is string &&
             data.price is number && data.price >= 0;
    }

    function isValidTestimonial(data) {
      return hasRequiredFields(['userId', 'content', 'rating']) &&
             data.userId is string &&
             data.content is string && data.content.size() < 5000 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && 
        (request.resource.data.role == 'user' || isAdmin());
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    // Custom Orders
    match /custom_orders/{customOrderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Add-ons
    match /addons/{addonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Promo Codes
    match /promo_codes/{promoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Projects (Templates)
    match /projects/{projectId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidTemplate(request.resource.data);
      allow delete: if isAdmin();
    }

    // Testimonials
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidTestimonial(request.resource.data)) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
